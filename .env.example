# ── NyayaVoice Environment Variables ──────────────────────
# Copy this file to .env and fill in your keys

# Gemini API — REQUIRED for AI responses
# Get free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Vapi keys — REQUIRED for voice calls
# Sign up at https://vapi.ai — use code "vapixhackblr" for $30 free credits
VAPI_API_KEY=your_vapi_api_key_here
VAPI_PUBLIC_KEY=your_vapi_public_key_here

# Qdrant — leave as :memory: for local dev (no Docker needed)
# Or sign up free at https://cloud.qdrant.io for persistent storage
QDRANT_URL=:memory:
QDRANT_API_KEY=

# Backend URL (used for document download links)
BACKEND_URL=http://localhost:8000
